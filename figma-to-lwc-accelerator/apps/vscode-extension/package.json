{
  "name": "figma-to-lwc-vscode",
  "displayName": "Figma to Salesforce LWC Generator",
  "description": "Generate standard Salesforce Lightning Web Components and SLDS layouts from Figma design screenshot images.",
  "version": "0.1.3",
  "publisher": "iamvikaas",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vikaschd04/Figma-LWC_Generator.git",
    "directory": "figma-to-lwc-accelerator/apps/vscode-extension"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/extension.js",
    "package.json",
    "README.md"
  ],
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "figma-to-lwc.generate",
        "title": "Figma to LWC: Generate Component from Image"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "figma-to-lwc.generate",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ]
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/jpeg-js": "^0.3.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "jpeg-js": "^0.4.4",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^25.3.0"
  }
}
