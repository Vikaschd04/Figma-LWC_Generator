{
  "name": "figma-to-lwc-accelerator",
  "version": "0.1.0",
  "private": true,
  "description": "Internal accelerator for converting Figma design data into Salesforce LWC-oriented code artifacts.",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "jest --runInBand --cacheDirectory ./.cache/jest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:backend": "tsx apps/backend/src/server.ts",
    "generate-samples": "tsx scripts/generate-samples.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.30.1",
    "jest": "^30.0.4",
    "jpeg-js": "^0.4.4",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "puppeteer": "^25.3.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "zod": "^4.4.3"
  }
}
