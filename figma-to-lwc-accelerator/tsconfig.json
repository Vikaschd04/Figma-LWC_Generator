{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["jest", "node"]
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts", "scripts/**/*.ts", "api/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
